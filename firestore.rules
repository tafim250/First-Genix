rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "mdtafim77889@gmail.com" ||
        (exists(/databases/$(database)/documents/settings/admin) && 
         request.auth.token.email == get(/databases/$(database)/documents/settings/admin).data.email)
      );
    }

    // HSK Exams Collection
    match /hsk_exams/{examId} {
      // Anyone authenticated can read mock exams
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete exams
      allow create, update, delete: if isAdmin();
    }

    // Settings Collection
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Results Collection (for future use if needed)
    match /results/{resultId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }
  }
}
