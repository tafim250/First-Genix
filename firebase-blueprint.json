{
  "entities": {
    "Question": {
      "title": "Question",
      "description": "A single question in an HSK exam",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["MCQ", "Writing", "Listening", "True/False"] },
        "section": { "type": "string", "enum": ["Listening", "Reading", "Writing"] },
        "level": { "type": "integer" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "optionImages": { "type": "array", "items": { "type": "string" } },
        "audioUrl": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "modelAnswer": { "type": "string" },
        "aiEvaluated": { "type": "boolean" },
        "audioScript": { "type": "string" },
        "maxMarks": { "type": "integer" },
        "partType": { "type": "string" },
        "passageId": { "type": "string" },
        "blanks": { "type": "array", "items": { "type": "object" } },
        "errorSentence": { "type": "string" },
        "optionPool": { "type": "array", "items": { "type": "string" } },
        "blankMapping": { "type": "object" }
      },
      "required": ["id", "type", "section", "text", "maxMarks"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An HSK exam",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "integer" },
        "duration": { "type": "integer" },
        "sectionDurations": { "type": "object" },
        "totalMarks": { "type": "integer" },
        "questions": { "type": "array", "items": { "$ref": "Question" } },
        "type": { "type": "string", "enum": ["mock", "practice", "real"] },
        "isInstant": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "scheduledTime": { "type": "integer" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "name", "duration", "questions"]
    },
    "ExamResult": {
      "title": "Exam Result",
      "description": "A user's exam result",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "examId": { "type": "string" },
        "examName": { "type": "string" },
        "level": { "type": "integer" },
        "score": { "type": "number" },
        "sectionScores": { "type": "object" },
        "totalMarks": { "type": "integer" },
        "passed": { "type": "boolean" },
        "date": { "type": "integer" },
        "answers": { "type": "object" },
        "feedback": { "type": "object" }
      },
      "required": ["id", "userId", "examId", "score", "passed", "date"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "A user's profile and settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "email", "isAdmin"]
    }
  },
  "firestore": {
    "/hsk_banks/{examId}": {
      "schema": "Exam",
      "description": "Collection of custom HSK exams"
    },
    "/results/{resultId}": {
      "schema": "ExamResult",
      "description": "Collection of user exam results"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "/analytics/global": {
      "schema": {
        "type": "object",
        "properties": {
          "visitCount": { "type": "integer" }
        }
      },
      "description": "Global analytics"
    }
  }
}
